# 绘卖AI邀请内测生产配置模板（只放变量名和占位符，绝不提交真实值）
NODE_ENV=production
HUIMAI_DEPLOYMENT_MODE=saas
TZ=Asia/Shanghai
HUIMAI_PUBLIC_BASE_URL=https://replace-with-production-host
# 每次部署的不可变 commit/image digest，用于 Golden 评测指纹
HUIMAI_CODE_VERSION=replace-with-build-commit-sha
# 最终预检必须在容器内命中同一实例，并核对 X-Huimai-Code-Version
HUIMAI_PREFLIGHT_READY_URL=http://127.0.0.1:3000/api/health/ready

# 持久卷与独立备份卷
APP_DATA_DIR=/data
APP_MIGRATIONS_DIR=/app/drizzle
BACKUP_DIR=/backups
# Web 只读挂载 /backups；专用维护任务写入后，用 ops:verify-backup 绑定冻结窗口和异机版本回执
HUIMAI_BACKUP_EVIDENCE_FILE=/release-evidence/backup-verification.json
HUIMAI_BACKUP_EVIDENCE_SHA256=replace-with-file-sha256
HUIMAI_BACKUP_OFFSITE_RECEIPT_FILE=/release-evidence/offsite-backup-receipt.json
HUIMAI_BACKUP_OFFSITE_RECEIPT_SHA256=replace-with-file-sha256
CLIPFORGE_MIN_FREE_DISK_BYTES=2147483648
# 每个商户可归属 uploads 的累计上限；邀请内测默认按 2 GiB 配置
HUIMAI_MERCHANT_UPLOAD_MAX_BYTES=2147483648
# Nginx 示例为 161 MiB；运行 pnpm ops:verify-edge 后填写证据 SHA-256
HUIMAI_EDGE_MAX_BODY_BYTES=168820736
HUIMAI_EDGE_BODY_LIMIT_PROBE_PATH=/api/project/edge-body-limit-probe/materials
# 在部署机对 `nginx -T` 的完整展开输出计算 SHA-256，再运行边缘探针
HUIMAI_EDGE_GATEWAY_CONFIG_SHA256=replace-with-nginx-expanded-config-sha256
HUIMAI_EDGE_BODY_LIMIT_EVIDENCE_FILE=/release-evidence/edge-body-limit.json
HUIMAI_EDGE_BODY_LIMIT_EVIDENCE_SHA256=replace-with-file-sha256
# 应用端口必须只绑定受信 Nginx；应用只读取 Nginx 覆盖写入的 X-Real-IP
HUIMAI_TRUST_PROXY=1
HUIMAI_CLIENT_IP_HEADER=x-real-ip

# 仅邮箱白名单；不要配置可重复邀请码
HUIMAI_INVITE_ONLY=1
HUIMAI_INVITE_EMAILS=owner-a@example.com,owner-b@example.com
HUIMAI_PUBLIC_SIGNUP=0

# 用密码管理器生成；两者必须不同
CLIPFORGE_ADMIN_PASSWORD=replace-with-random-16-plus-characters
CLIPFORGE_ADMIN_SESSION_SECRET=replace-with-independent-random-32-plus-characters

# 真实运营与合规信息
HUIMAI_LEGAL_ENTITY=replace-with-real-operator
HUIMAI_LEGAL_CONTACT=replace-with-real-support-channel
HUIMAI_DATA_RETENTION_DAYS=30
HUIMAI_AI_PROVIDER_DISCLOSURE=replace-with-enabled-model-providers
HUIMAI_AIGC_SERVICE_PROVIDER=replace-with-provider-name-or-code

# 固定版本文本/视觉模型；主备应跨供应商故障域
CLIPFORGE_LLM_PROVIDER=replace-with-primary-provider
CLIPFORGE_LLM_BASE_URL=https://replace-with-primary-api-host/v1
CLIPFORGE_LLM_MODEL=replace-with-pinned-model-id
# 单端点只允许一个 revision；留空或与 LLM_MODEL 完全相同，不能填写另一个视觉模型
CLIPFORGE_LLM_VISION_MODEL=replace-with-same-pinned-model-id
CLIPFORGE_LLM_DEPLOYMENT_REVISION=replace-with-immutable-provider-revision
CLIPFORGE_LLM_REVISION_EVIDENCE_FILE=llm-primary.json
CLIPFORGE_LLM_REVISION_EVIDENCE_SHA256=replace-with-file-sha256
CLIPFORGE_LLM_API_KEY=replace-with-deployment-secret
CLIPFORGE_LLM_FALLBACK_PROVIDER=replace-with-different-provider
CLIPFORGE_LLM_FALLBACK_BASE_URL=https://replace-with-fallback-api-host/v1
CLIPFORGE_LLM_FALLBACK_MODEL=replace-with-pinned-fallback-model-id
# 留空或与 LLM_FALLBACK_MODEL 完全相同
CLIPFORGE_LLM_FALLBACK_VISION_MODEL=replace-with-same-pinned-fallback-model-id
CLIPFORGE_LLM_FALLBACK_DEPLOYMENT_REVISION=replace-with-immutable-provider-revision
CLIPFORGE_LLM_FALLBACK_REVISION_EVIDENCE_FILE=llm-fallback.json
CLIPFORGE_LLM_FALLBACK_REVISION_EVIDENCE_SHA256=replace-with-file-sha256
CLIPFORGE_LLM_FALLBACK_API_KEY=replace-with-deployment-secret

# 图片主备
CLIPFORGE_IMAGE_PROVIDER=replace-with-primary-provider
CLIPFORGE_IMAGE_BASE_URL=https://replace-with-primary-api-host/v1
CLIPFORGE_IMAGE_MODEL=replace-with-pinned-model-id
CLIPFORGE_IMAGE_DEPLOYMENT_REVISION=replace-with-immutable-provider-revision
CLIPFORGE_IMAGE_REVISION_EVIDENCE_FILE=image-primary.json
CLIPFORGE_IMAGE_REVISION_EVIDENCE_SHA256=replace-with-file-sha256
CLIPFORGE_IMAGE_API_KEY=replace-with-deployment-secret
CLIPFORGE_IMAGE_FALLBACK_PROVIDER=replace-with-different-provider
CLIPFORGE_IMAGE_FALLBACK_BASE_URL=https://replace-with-fallback-api-host/v1
CLIPFORGE_IMAGE_FALLBACK_MODEL=replace-with-pinned-model-id
CLIPFORGE_IMAGE_FALLBACK_DEPLOYMENT_REVISION=replace-with-immutable-provider-revision
CLIPFORGE_IMAGE_FALLBACK_REVISION_EVIDENCE_FILE=image-fallback.json
CLIPFORGE_IMAGE_FALLBACK_REVISION_EVIDENCE_SHA256=replace-with-file-sha256
CLIPFORGE_IMAGE_FALLBACK_API_KEY=replace-with-deployment-secret

# 视频主备
CLIPFORGE_VIDEO_PROVIDER=replace-with-primary-provider
CLIPFORGE_VIDEO_BASE_URL=https://replace-with-primary-api-host/v1
CLIPFORGE_VIDEO_MODEL=replace-with-pinned-model-id
CLIPFORGE_VIDEO_DEPLOYMENT_REVISION=replace-with-immutable-provider-revision
CLIPFORGE_VIDEO_REVISION_EVIDENCE_FILE=video-primary.json
CLIPFORGE_VIDEO_REVISION_EVIDENCE_SHA256=replace-with-file-sha256
CLIPFORGE_VIDEO_API_KEY=replace-with-deployment-secret
CLIPFORGE_VIDEO_FALLBACK_PROVIDER=replace-with-different-provider
CLIPFORGE_VIDEO_FALLBACK_BASE_URL=https://replace-with-fallback-api-host/v1
CLIPFORGE_VIDEO_FALLBACK_MODEL=replace-with-pinned-model-id
CLIPFORGE_VIDEO_FALLBACK_DEPLOYMENT_REVISION=replace-with-immutable-provider-revision
CLIPFORGE_VIDEO_FALLBACK_REVISION_EVIDENCE_FILE=video-fallback.json
CLIPFORGE_VIDEO_FALLBACK_REVISION_EVIDENCE_SHA256=replace-with-file-sha256
CLIPFORGE_VIDEO_FALLBACK_API_KEY=replace-with-deployment-secret

# TTS 主备。豆包语音使用独立语音控制台 API Key，不可复用方舟 ARK Key。
CLIPFORGE_TTS_PROVIDER=volcengine
CLIPFORGE_TTS_BASE_URL=https://openspeech.bytedance.com/api/v3/tts
CLIPFORGE_TTS_MODEL=seed-tts-2.0
CLIPFORGE_TTS_DEPLOYMENT_REVISION=replace-with-immutable-provider-revision
CLIPFORGE_TTS_REVISION_EVIDENCE_FILE=tts-primary.json
CLIPFORGE_TTS_REVISION_EVIDENCE_SHA256=replace-with-file-sha256
CLIPFORGE_TTS_VOICE=zh_female_vv_uranus_bigtts
CLIPFORGE_TTS_API_KEY=replace-with-deployment-secret
CLIPFORGE_TTS_FALLBACK_PROVIDER=replace-with-different-provider
CLIPFORGE_TTS_FALLBACK_BASE_URL=https://replace-with-fallback-api-host/v1
CLIPFORGE_TTS_FALLBACK_MODEL=replace-with-pinned-model-id
CLIPFORGE_TTS_FALLBACK_DEPLOYMENT_REVISION=replace-with-immutable-provider-revision
CLIPFORGE_TTS_FALLBACK_REVISION_EVIDENCE_FILE=tts-fallback.json
CLIPFORGE_TTS_FALLBACK_REVISION_EVIDENCE_SHA256=replace-with-file-sha256
CLIPFORGE_TTS_FALLBACK_VOICE=replace-with-voice-id
CLIPFORGE_TTS_FALLBACK_API_KEY=replace-with-deployment-secret

# 仅自定义 API 主机需要；多个主机逗号分隔
HUIMAI_MODEL_ENDPOINT_HOSTS=replace-with-custom-primary-host,replace-with-custom-fallback-host
# 每个自定义主机必须声明真实供应商故障域；同一上游的不同域名必须映射为同一个值
HUIMAI_MODEL_ENDPOINT_FAULT_DOMAINS=replace-with-custom-primary-host=provider-a,replace-with-custom-fallback-host=provider-b
# 只读挂载的供应商控制台 revision/deployment 证据；预检逐文件核对上述 SHA-256
HUIMAI_MODEL_REVISION_EVIDENCE_DIR=/model-revision-evidence

# Golden 媒体评测：仅允许从这些 CDN/产物主机下载，支持 *.example.com
HUIMAI_EVAL_ARTIFACT_HOSTS=replace-with-provider-artifact-host
# 单次媒体生成的平均实际成本上限（USD）；未配置会 fail-closed 阻止候选晋级
HUIMAI_EVAL_MAX_IMAGE_COST_USD=replace-with-approved-image-cost
HUIMAI_EVAL_MAX_VIDEO_COST_USD=replace-with-approved-video-cost
HUIMAI_EVAL_MAX_TTS_COST_USD=replace-with-approved-tts-cost
# 评测产物总容量和单记录上限（bytes）
HUIMAI_EVAL_STORAGE_MAX_BYTES=2147483648
HUIMAI_EVAL_MAX_RECORD_BYTES=262144000

# 运维告警阈值（按内测容量调整）
HUIMAI_ALERT_PENDING_JOBS=5
HUIMAI_ALERT_PENDING_AGE_MS=600000
HUIMAI_ALERT_MODEL_FAILURE_RATE=0.2
HUIMAI_ALERT_RATE_LIMIT_COUNT=3
HUIMAI_ALERT_BACKUP_AGE_MS=25200000
HUIMAI_ALERT_DAILY_COST_USD=replace-with-approved-daily-budget
